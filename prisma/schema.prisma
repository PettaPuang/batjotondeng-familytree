generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
}

enum PersonAuditAction {
  CREATE
  UPDATE
  DELETE
}

model Person {
  id         String    @id @default(cuid())
  fullName   String
  nickname   String?
  gender     Gender
  birthDate  DateTime?
  birthPlace String?
  isAlive    Boolean   @default(true)
  deathDate  DateTime?
  photoUrl   String?
  phone      String?
  address    String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([birthDate])
  @@index([fullName])

  marriages    Marriage[]       @relation("Husband")
  marriages2   Marriage[]       @relation("Wife")
  parents      PersonParent[]   @relation("Child")
  auditActions PersonAuditLog[] @relation("PersonAuditActor")
}

model Marriage {
  id           String    @id @default(cuid())
  husbandId    String
  wifeId       String
  marriageDate DateTime?
  isActive     Boolean   @default(true)

  husband  Person         @relation("Husband", fields: [husbandId], references: [id], onDelete: Cascade)
  wife     Person         @relation("Wife", fields: [wifeId], references: [id], onDelete: Cascade)
  children PersonParent[]

  @@unique([husbandId, wifeId])
}

model PersonParent {
  id         String @id @default(cuid())
  childId    String
  marriageId String

  child    Person   @relation("Child", fields: [childId], references: [id], onDelete: Cascade)
  marriage Marriage @relation(fields: [marriageId], references: [id], onDelete: Cascade)

  @@unique([childId, marriageId])
}

model PersonAuditLog {
  id            String            @id @default(cuid())
  personId      String
  personName    String?
  action        PersonAuditAction
  actorPersonId String
  actorName     String?
  changes       Json
  createdAt     DateTime          @default(now())

  actor Person @relation("PersonAuditActor", fields: [actorPersonId], references: [id], onDelete: Restrict)

  @@index([personId, createdAt(sort: Desc)])
}
